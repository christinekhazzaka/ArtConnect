<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.ArtistController">

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search artists..." HBox.hgrow="ALWAYS" />
        <ComboBox fx:id="disciplineFilter" promptText="Filter by Discipline" />
        <Button text="Search" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleReset" />
    </HBox>

    <GridPane hgap="10.0" vgap="8.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="15" />
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="15" />
            <ColumnConstraints percentWidth="35" />
        </columnConstraints>

        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="nameField" promptText="Artist name" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Email:" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <TextField fx:id="emailField" promptText="Email" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="City:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="cityField" promptText="City" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Birth year:" GridPane.rowIndex="1" GridPane.columnIndex="2" />
        <TextField fx:id="birthYearField" promptText="Birth year" GridPane.rowIndex="1" GridPane.columnIndex="3" />

        <Label text="Biography:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextField fx:id="bioField" promptText="Biography" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Discipline:" GridPane.rowIndex="2" GridPane.columnIndex="2" />
        <ComboBox fx:id="disciplineField" promptText="Discipline" GridPane.rowIndex="2" GridPane.columnIndex="3" />
    </GridPane>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button text="Add Artist" onAction="#handleAddArtist" />
        <Button text="Update Artist" onAction="#handleUpdateArtist" />
        <Button text="Delete Artist" onAction="#handleDeleteArtist" />
    </HBox>

    <TableView fx:id="artistTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="200" />
            <TableColumn fx:id="cityColumn" text="City" prefWidth="150" />
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="200" />
            <TableColumn fx:id="yearColumn" text="Birth Year" prefWidth="100" />
            <TableColumn fx:id="disciplineColumn" text="Discipline" prefWidth="150" />
            <TableColumn fx:id="bioColumn" text="Biography" prefWidth="360" />
        </columns>
    </TableView>
</VBox>
