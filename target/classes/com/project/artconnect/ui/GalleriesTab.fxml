<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.artconnect.ui.GalleryController">

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>

    <GridPane hgap="10.0" vgap="8.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="15" />
            <ColumnConstraints percentWidth="35" />
            <ColumnConstraints percentWidth="15" />
            <ColumnConstraints percentWidth="35" />
        </columnConstraints>

        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="nameField" promptText="Gallery name" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Address:" GridPane.rowIndex="0" GridPane.columnIndex="2" />
        <TextField fx:id="addressField" promptText="Gallery address" GridPane.rowIndex="0" GridPane.columnIndex="3" />

        <Label text="Rating:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="ratingField" promptText="Rating (0-5)" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button text="Add Gallery" fx:id="addButton" onAction="#handleAddGallery" />
        <Button text="Update Gallery" fx:id="updateButton" onAction="#handleUpdateGallery" />
        <Button text="Delete Gallery" fx:id="deleteButton" onAction="#handleDeleteGallery" />
    </HBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="Search:" />
        <TextField fx:id="searchField" promptText="Search gallery by name" HBox.hgrow="ALWAYS" />
        <Button text="Search" fx:id="searchButton" onAction="#handleSearch" />
        <Button text="Reset" onAction="#handleResetSearch" />
    </HBox>

    <TableView fx:id="galleryTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="250" />
            <TableColumn fx:id="addressColumn" text="Address" prefWidth="350" />
            <TableColumn fx:id="ratingColumn" text="Rating" prefWidth="120" />
        </columns>
    </TableView>
</VBox>
